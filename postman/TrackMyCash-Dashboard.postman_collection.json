{
  "info": {
    "_postman_id": "8c0bf25d-9e4b-4788-b837-b33566a70a62",
    "name": "TrackMyCash Dashboard API",
    "description": "Collection for testing authentication and dashboard overview APIs in TrackMyCash.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "email",
      "value": "john.doe@example.com"
    },
    {
      "key": "password",
      "value": "Password@123"
    },
    {
      "key": "timeZone",
      "value": "Asia/Kolkata"
    },
    {
      "key": "authToken",
      "value": ""
    },
    {
      "key": "dashboardDays",
      "value": "30"
    },
    {
      "key": "dashboardPeriodLabel",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const res = pm.response.json();",
                  "pm.test('Login success true', function () {",
                  "  pm.expect(res.success).to.eql(true);",
                  "});",
                  "",
                  "if (res && res.success && res.data && res.data.token) {",
                  "  pm.collectionVariables.set('authToken', res.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"timezone\": \"{{timeZone}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/client/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "client",
                "v1",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard Overview (Default)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const res = pm.response.json();",
                  "pm.test('Response success true', function () {",
                  "  pm.expect(res.success).to.eql(true);",
                  "});",
                  "",
                  "pm.test('Dashboard data shape exists', function () {",
                  "  pm.expect(res.data).to.have.property('summary');",
                  "  pm.expect(res.data).to.have.property('charts');",
                  "  pm.expect(res.data).to.have.property('recentTransactions');",
                  "  pm.expect(res.data).to.have.property('topSpendingCategories');",
                  "});",
                  "",
                  "if (res && res.data && res.data.summary && res.data.summary.periodLabel) {",
                  "  pm.collectionVariables.set('dashboardPeriodLabel', res.data.summary.periodLabel);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "_next_refresh_token_tmc_={{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/client/v1/dashboard",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "client",
                "v1",
                "dashboard"
              ]
            }
          },
          "response": []
        },
