                "key": "Cookie",
                "value": "_next_refresh_token_tmc_={{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/client/v1/categories/{{categoryId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
