{
  "info": {
    "_postman_id": "8f9fbd3d-6db9-4f6b-9f62-6e1d93e9c121",
    "name": "TrackMyCash Categories API",
    "description": "Collection for testing auth and category CRUD endpoints in TrackMyCash.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "email",
      "value": "john.doe@example.com"
    },
    {
      "key": "password",
      "value": "Password@123"
    },
    {
      "key": "timeZone",
      "value": "Asia/Kolkata"
    },
    {
      "key": "role",
      "value": "USER"
    },
    {
      "key": "authToken",
      "value": ""
    },
    {
      "key": "categoryId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"timeZone\": \"{{timeZone}}\",\n  \"role\": \"{{role}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/client/v1/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "client",
                "v1",
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const res = pm.response.json();",
                  "if (res && res.success && res.data && res.data.token) {",
                  "  pm.collectionVariables.set('authToken', res.data.token);",
                  "}",
                  ""
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"timezone\": \"{{timeZone}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/client/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "client",
                "v1",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const res = pm.response.json();",
                  "if (res && res.success && res.data && res.data._id) {",
                  "  pm.collectionVariables.set('categoryId', res.data._id);",
                  "}",
                  ""
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Cookie",
                "value": "_next_refresh_token_tmc_={{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Marketing\",\n  \"icon\": \"megaphone\",\n  \"color\": \"#ffb596\",\n  \"type\": \"expense\",\n  \"overline\": \"Q2 Campaigns\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/client/v1/categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "client",
                "v1",
                "categories"
              ]
            }
          },
          "response": []
        },
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "_next_refresh_token_tmc_={{authToken}}"
